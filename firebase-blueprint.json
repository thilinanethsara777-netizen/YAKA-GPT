{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and metadata",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique user ID" },
        "displayName": { "type": "string", "description": "The user's display name" },
        "email": { "type": "string", "description": "The user's email" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation timestamp" }
      },
      "required": ["uid", "createdAt"]
    },
    "Memory": {
      "title": "Memory",
      "description": "Important facts the AI should remember about the user",
      "type": "object",
      "properties": {
        "content": { "type": "string", "description": "The fact or memory content" },
        "importance": { "type": "integer", "description": "How important this fact is (1-10)" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When this memory was created" }
      },
      "required": ["content", "createdAt"]
    },
    "Message": {
      "title": "Message",
      "description": "A single chat message",
      "type": "object",
      "properties": {
        "role": { "type": "string", "enum": ["user", "model"] },
        "text": { "type": "string" },
        "image": { "type": "string", "description": "Base64 image data or URL" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["role", "text", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/users/{userId}/memories/{memoryId}": {
      "schema": "Memory",
      "description": "Personal facts and memories"
    },
    "/users/{userId}/chats/{chatId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Chat message history"
    }
  }
}
